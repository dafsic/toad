# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_TELEGRAM_USER_ID=123456789

# Kraken 现货 API
KRAKEN_API_KEY=your_kraken_api_key_here
KRAKEN_API_SECRET=your_kraken_api_secret_here

# MEXC 现货 API
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# Hyperliquid 永续合约
# API 钱包私钥（十六进制，可选 0x 前缀）
HYPERLIQUID_PRIVATE_KEY=your_private_key_here
# 主账户地址（当私钥为 API agent wallet 时必填；普通钱包可留空）
HYPERLIQUID_ACCOUNT_ADDRESS=
# 是否使用测试网（留空或 false 为主网，设为 true 连接测试网）
HYPERLIQUID_TESTNET=false

# 服务监听地址（容器内）
SERVER_ADDR=0.0.0.0:3000

# 数据库路径（容器内 volume 挂载路径）
DATABASE_URL=/data/bot.db

# JWT 密钥（用于保护 API 访问，生产环境请使用更安全的密钥）
JWT_SECRET=change-me-in-production-please-use-a-long-random-string

# ── Docker 镜像（CI 推送到 DockerHub: <DOCKER_USERNAME>/toad）─────────────────
# 你的 DockerHub 用户名；设置后 docker compose 将拉取 CI 已发布镜像。
# 留空则使用本地构建产物（执行 `docker compose build`）。
DOCKER_USERNAME=
# 镜像标签：latest 跟随 main 分支；或固定到语义化版本（如 0.1.0，对应 git tag v0.1.0）
TOAD_TAG=latest